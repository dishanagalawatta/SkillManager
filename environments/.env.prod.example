# =============================================================================
# SkillManager — Production Environment
# =============================================================================
# Copy to .env in the project root for production builds.
# Overrides: error-level logging, telemetry tokens required.
# =============================================================================

# ---- Qt / QML ----
QT_QUICK_CONTROLS_STYLE=Basic
QML_DISABLE_DISK_CACHE=1

# ---- Application ----
SKILL_MANAGER_LOG_LEVEL=ERROR

# ---- Telemetry (required in prod) ----
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=
SENTRY_DSN=
