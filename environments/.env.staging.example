# =============================================================================
# SkillManager — Staging Environment
# =============================================================================
# Copy to .env in the project root for staging/CI builds.
# Overrides: real PostHog project, Sentry DSN slot, warning-level logging.
# =============================================================================

# ---- Qt / QML ----
QT_QUICK_CONTROLS_STYLE=Basic
QML_DISABLE_DISK_CACHE=1
QT_QPA_PLATFORM=offscreen

# ---- Application ----
SKILL_MANAGER_TESTING=1
SKILL_MANAGER_SKIP_INITIAL_LOAD=1
SKILL_MANAGER_DATA_DIR=
SKILL_MANAGER_LOG_LEVEL=WARNING

# ---- Telemetry (fill in for staging) ----
POSTHOG_PROJECT_TOKEN=<set_locally>
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=<set_locally>
