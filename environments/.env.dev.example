# =============================================================================
# SkillManager — Development Environment
# =============================================================================
# Copy to .env in the project root for local development.
# Overrides: QML_DISABLE_DISK_CACHE=1, headless Qt, verbose logging.
# =============================================================================

# ---- Qt / QML ----
QT_QUICK_CONTROLS_STYLE=Basic
QML_DISABLE_DISK_CACHE=1
QT_QPA_PLATFORM=offscreen

# ---- Application ----
SKILL_MANAGER_TESTING=1
SKILL_MANAGER_SKIP_INITIAL_LOAD=1
SKILL_MANAGER_DATA_DIR=
SKILL_MANAGER_LOG_LEVEL=DEBUG

# ---- Telemetry (disabled in dev) ----
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=
SENTRY_DSN=
