# =============================================================================
# SkillManager — Environment Variables
# =============================================================================
# Copy this file to `.env` and uncomment / set values as needed.
# `.env` is in .gitignore; never commit secrets.
# =============================================================================

# ----- Test / CI -----
# Force QML import path resolution to "Basic" so styling is consistent in
# headless test environments. Must be set BEFORE Qt starts.
QT_QUICK_CONTROLS_STYLE=Basic

# Qt platform plugin. CI / headless tests pin "offscreen".
# Leave unset in normal use to get the native platform.
# QT_QPA_PLATFORM=offscreen

# Disable the QML disk cache. PySide6 6.11.1 serves stale cached bytecode
# after QML source changes; disabling forces recompilation and removes a
# class of "works on my machine" bugs. Set user-scope permanently.
QML_DISABLE_DISK_CACHE=1

# Mark the process as under test. AppController skips non-essential startup
# work (analytics, real network calls, persisted state restoration) when set.
SKILL_MANAGER_TESTING=1
SKILL_MANAGER_SKIP_INITIAL_LOAD=1

# Override the data directory. Defaults to %APPDATA%/SkillManager on Windows
# and ~/.local/share/SkillManager on Linux. Tests should set this to a
# per-run tempdir to avoid clobbering real data.
# SKILL_MANAGER_DATA_DIR=/path/to/data

# ----- Analytics (PostHog) -----
# Project token for self-hosted or cloud PostHog telemetry. Empty disables.
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=

# ----- Logging -----
# Log level for the QML console bridge. One of: DEBUG, INFO, WARNING, ERROR.
SKILL_MANAGER_LOG_LEVEL=INFO
