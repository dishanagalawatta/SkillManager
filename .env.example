# =============================================================================
# SkillManager — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# For tier-specific defaults, see environments/.env.{dev,staging,prod}.example
# Canonical docs: docs/ENVIRONMENT.md
# =============================================================================

# ---- Qt / QML ----
# QT_QUICK_CONTROLS_STYLE=Basic   # Default style (Basic, Material, Universal)
# QML_DISABLE_DISK_CACHE=1         # Set to 1 for dev/test; omit for prod
# QT_QPA_PLATFORM=offscreen        # Set for headless/CI environments

# ---- Application ----
# SKILL_MANAGER_TESTING=1          # Enable test mode (disables telemetry, polling)
# SKILL_MANAGER_SKIP_INITIAL_LOAD=1 # Skip initial skill discovery on startup
# SKILL_MANAGER_DATA_DIR=          # Override default data directory (empty = default)
# SKILL_MANAGER_LOG_LEVEL=INFO     # DEBUG | INFO | WARNING | ERROR

# ---- Telemetry ----
# PostHog: anonymous product analytics (disabled in dev/test)
POSTHOG_PROJECT_TOKEN=<your_posthog_project_token>
POSTHOG_HOST=https://us.i.posthog.com

# Sentry: error tracking (optional; leave empty to disable)
SENTRY_DSN=<your_sentry_dsn>
