# =============================================================================
# SkillManager — Environment Variables
# =============================================================================
# Copy to .env. .env is git-ignored. Never commit secrets.
# See environments/README.md for tier-specific overrides.
# =============================================================================

# ---- Qt / QML ----
QT_QUICK_CONTROLS_STYLE=Basic
QML_DISABLE_DISK_CACHE=1
# QT_QPA_PLATFORM=offscreen       # CI / headless only

# ---- Application ----
# SKILL_MANAGER_TESTING=1          # Skip analytics/network/state-restore
# SKILL_MANAGER_SKIP_INITIAL_LOAD=1
# SKILL_MANAGER_DATA_DIR=          # Override user data dir (platformdirs default)
SKILL_MANAGER_LOG_LEVEL=INFO      # DEBUG | INFO | WARNING | ERROR

# ---- Telemetry (empty disables) ----
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=
SENTRY_DSN=
