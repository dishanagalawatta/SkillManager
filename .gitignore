# SkillManager — .gitignore
# Canonical cleanup rules: docs/HOUSEKEEPING.md
# Architectural decisions: docs/adr/ADR-0016 (.opencode), ADR-0018 (standardization)

# ─── IDE / Editor ────────────────────────────────────────────────
.vscode/settings.json
*.code-workspace
.idea/
*.iml

# ─── OS / Desktop ────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store
*~

# ─── Python ──────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.mypy_cache/
.venv/
venv/

# ─── Testing / Linting ──────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/

# ─── Qt / PySide6 ───────────────────────────────────────────────
.qmlcache/
.qmltypes/
*.qmlc
*.jsc

# ─── Runtime State (regenerable) ─────────────────────────────────
# Per ADR-0018: data/ is user runtime; app recreates on first run.
data/
cache_dump.txt
*.log

# ─── Deprecated Artifacts (ADR-0010) ─────────────────────────────
tuf_keys/
tuf_repo/
.tufup-repo-config

# ─── Agent / Local Tooling ──────────────────────────────────────
# Per ADR-0016: .opencode/ is local agent config, never committed.
.opencode/

# ─── Secrets (never commit) ─────────────────────────────────────
# .env contains live API tokens (PostHog, Sentry, etc.)
# Use .env.example as the canonical template.
.env
