    def checkMissingSkills(self, name: str) -> str: ...
    def copyMissingSkills(self, name: str, project_labels: list) -> None: ...
    def getCollectionsDiagnostic(self) -> str: ...
    def getProjectResolutionTable(self) -> str: ...
