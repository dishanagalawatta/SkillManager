    def save_cache(self, data: dict) -> None: ...
    def load_cache(self) -> dict: ...
    def getDiagnosticLogPath(self) -> str: ...
    def getRecentDiagnosticEvents(self, count: int = ...) -> str: ...
    def exportDiagnosticBundle(self, output_dir: str = ...) -> str: ...
